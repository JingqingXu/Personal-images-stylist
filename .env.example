# 上传大小限制（MB）
MAX_UPLOAD_MB=10

# Flask 运行端口
PORT=5000

# 千问（DashScope OpenAI兼容）
DASHSCOPE_API_KEY=your_dashscope_api_key
QWEN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen-vl-max-latest

# 换装模型接口（按你实际服务替换）
TRYON_API_URL=
TRYON_API_KEY=
TRYON_MODEL=virtual-try-on
